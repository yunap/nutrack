# Required
ANTHROPIC_API_KEY=your_api_key_here
PORT=7000

# OAuth (optional — auth disabled when these are absent)
# Get Google credentials: https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Get GitHub credentials: https://github.com/settings/developers
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Required when OAuth is enabled
# BASE_URL=https://your-domain.com
# SESSION_SECRET=generate-with-openssl-rand-hex-32

# Set to 'production' when behind HTTPS
# NODE_ENV=production
